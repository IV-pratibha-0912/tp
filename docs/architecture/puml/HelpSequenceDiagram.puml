@startuml
!include style.puml
skinparam ArrowFontStyle plain

Actor User as user

box UI UI_COLOR_1
participant ":MainWindow" as MainWindow UI_COLOR
participant ":HelpWindow" as HelpWindow UI_COLOR
end box

box Logic LOGIC_COLOR_1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":FairShareParser" as FairShareParser LOGIC_COLOR
participant "h:HelpCommand" as HelpCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

user -> MainWindow : inputs "help"
activate MainWindow

MainWindow -> LogicManager : execute("help")
activate LogicManager

LogicManager -> FairShareParser : parseCommand("help")
activate FairShareParser

create HelpCommand
FairShareParser -> HelpCommand : new
activate HelpCommand

HelpCommand --> FairShareParser : h
deactivate HelpCommand

FairShareParser --> LogicManager : h
deactivate FairShareParser

LogicManager -> HelpCommand : execute(m)
activate HelpCommand

create CommandResult
HelpCommand -> CommandResult : new("Displaying help window", true, false)
activate CommandResult
CommandResult --> HelpCommand : r
deactivate CommandResult

HelpCommand --> LogicManager : r
deactivate HelpCommand

LogicManager --> MainWindow : r
deactivate LogicManager

MainWindow -> HelpWindow : show()
MainWindow --> user : help window displayed
deactivate MainWindow
@enduml
