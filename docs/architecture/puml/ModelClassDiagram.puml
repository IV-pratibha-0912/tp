@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR
skinparam nodesep 60
skinparam ranksep 60

Package Model as ModelPackage <<Rectangle>>{
    Class "<<interface>>\nReadOnlyExpenseTracker" as ReadOnlyExpenseTracker
    Class "<<interface>>\nModel" as Model
    Class ExpenseTracker
    Class ModelManager
    Class DebtCalculator <<Utility>>
    Class Balance

    Class UniqueExpenseList
    Class Expense
    Class Person
    Class Tag

}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

ModelManager -right-> DebtCalculator : " uses"
DebtCalculator -down-> "*" Balance : " creates"

ExpenseTracker .up.|> ReadOnlyExpenseTracker
ModelManager .up.|> Model

Model .down.> ReadOnlyExpenseTracker
ModelManager -left-> "1" ExpenseTracker

ExpenseTracker *--> "1" UniqueExpenseList
UniqueExpenseList --> "~* all" Expense

Expense *-down-> "1" Person : payer >
Expense *-down-> "*" Person : shares >
Expense *-down-> "*" Tag

ModelManager ----> "~* filtered" Expense
@enduml