@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor UI_COLOR_4
skinparam classBackgroundColor UI_COLOR

package UI <<Rectangle>>{
    Class "<<interface>>\nUi" as Ui
    Class MainWindow
    Class Header
    Class ExpenseListPanel
    Class ExpenseCard
    Class BalancePanel
    Class BalanceCard
    Class TagPieChart
    Class StatusBar
    Class GroupWindow
    Class ResultDisplay
    Class CommandBox
    Class HelpWindow
}

package Model <<Rectangle>> {
    Class HiddenModel #FFFFFF
}

package Logic <<Rectangle>> {
    Class HiddenLogic #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Ui

' MainWindow implements UI interface
MainWindow .up.|> Ui

MainWindow *-down-> "1" Header
MainWindow *-down-> "1" ExpenseListPanel
MainWindow *-down-> "1" BalancePanel
MainWindow *-down-> "1" TagPieChart
MainWindow *-down-> "1" StatusBar
MainWindow *-down-> "1" ResultDisplay
MainWindow *-down-> "1" CommandBox
MainWindow *-down-> "0..1" HelpWindow
MainWindow *-down-> "0..1" GroupWindow

' Scroll pane contains multiple expense cards
ExpenseListPanel -down-> "*" ExpenseCard
BalancePanel -down-> "*" BalanceCard

ExpenseCard ..> Model
BalanceCard ..> Model
TagPieChart ..> Model
StatusBar ..> Model
GroupWindow ..> Model

' MainWindow passes the user input to Logic
MainWindow -right-> Logic

' Hints to keep the diagram wide and readable
Header -[hidden]right- ExpenseListPanel
ExpenseListPanel -[hidden]right- BalancePanel
BalancePanel -[hidden]right- TagPieChart
TagPieChart -[hidden]right- StatusBar
StatusBar -[hidden]right- ResultDisplay
ResultDisplay -[hidden]right- CommandBox

@enduml
