@startuml
!include style.puml
skinparam ArrowFontStyle plain

Actor User as user

box UI UI_COLOR_1
participant ":MainWindow" as MainWindow UI_COLOR
end box

box Logic LOGIC_COLOR_1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":FairShareParser" as FairShareParser LOGIC_COLOR
participant ":SettleCommandParser" as SettleCommandParser LOGIC_COLOR
participant "s:SettleCommand" as SettleCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_1
participant "m:Model" as Model MODEL_COLOR
end box

user -> MainWindow : inputs "settle g/JB p/alice r/bob a/10"
activate MainWindow

MainWindow -> LogicManager : execute("settle ...")
activate LogicManager

LogicManager -> FairShareParser : parseCommand("settle ...")
activate FairShareParser

create SettleCommandParser
FairShareParser -> SettleCommandParser : new
activate SettleCommandParser

FairShareParser -> SettleCommandParser : parse(args)
SettleCommandParser -> SettleCommandParser : tokenize and parse fields
SettleCommandParser -> SettleCommandParser : create settlement expense

create SettleCommand
SettleCommandParser -> SettleCommand : new(settlement)
activate SettleCommand

SettleCommand --> SettleCommandParser : s
deactivate SettleCommand

SettleCommandParser --> FairShareParser : s
deactivate SettleCommandParser
destroy SettleCommandParser

FairShareParser --> LogicManager : s
deactivate FairShareParser

LogicManager -> SettleCommand : execute(m)
activate SettleCommand

SettleCommand -> Model : addExpense(settlement)
activate Model
Model --> SettleCommand
deactivate Model

create CommandResult
SettleCommand -> CommandResult : new("Settlement added successfully", false, false)
activate CommandResult
CommandResult --> SettleCommand : r
deactivate CommandResult

SettleCommand --> LogicManager : r
deactivate SettleCommand

LogicManager --> MainWindow : r
deactivate LogicManager

MainWindow --> user : displays "Settlement added successfully"
deactivate MainWindow
@enduml
