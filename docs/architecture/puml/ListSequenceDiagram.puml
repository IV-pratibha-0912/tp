@startuml
!include style.puml
skinparam ArrowFontStyle plain

Actor User as user

box UI UI_COLOR_1
participant ":MainWindow" as MainWindow UI_COLOR
end box

box Logic LOGIC_COLOR_1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":FairShareParser" as FairShareParser LOGIC_COLOR
participant "l:ListCommand" as ListCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_1
participant "m:Model" as Model MODEL_COLOR
end box

user -> MainWindow : inputs "list"
activate MainWindow

MainWindow -> LogicManager : execute("list")
activate LogicManager

LogicManager -> FairShareParser : parseCommand("list")
activate FairShareParser

create ListCommand
FairShareParser -> ListCommand : new
activate ListCommand

ListCommand --> FairShareParser : l
deactivate ListCommand

FairShareParser --> LogicManager : l
deactivate FairShareParser

LogicManager -> ListCommand : execute(m)
activate ListCommand

ListCommand -> Model : filterExpenses(expense -> true)
activate Model
Model --> ListCommand
deactivate Model

create CommandResult
ListCommand -> CommandResult : new("Listing all expenses.", false, false)
activate CommandResult
CommandResult --> ListCommand : r
deactivate CommandResult

ListCommand --> LogicManager : r
deactivate ListCommand

LogicManager --> MainWindow : r
deactivate LogicManager

MainWindow --> user : displays "Listing all expenses."
deactivate MainWindow
@enduml
