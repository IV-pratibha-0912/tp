<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<HBox xmlns:fx="http://javafx.com/fxml"
      alignment="CENTER_LEFT"
      spacing="12"
      style="-fx-background-color: #4a7fe8;
             -fx-effect: dropshadow(gaussian,
                         rgba(0,0,0,0.15), 6, 0, 0, 2);">
    <padding>
        <Insets top="14" right="20" bottom="14" left="20"/>
    </padding>

    <ImageView fitWidth="100"
               fitHeight="100"
               preserveRatio="true">
        <image>
            <Image url="@/images/fairshare_logo.png"/>
        </image>
    </ImageView>

    <VBox spacing="2">
        <Label text="FairShare"
               style="-fx-font-size: 22;
                      -fx-font-weight: bold;
                      -fx-text-fill: white;"/>
        <Label text="Shared Expense Tracker"
               style="-fx-font-size: 11;
                      -fx-text-fill: rgba(255,255,255,0.75);"/>
    </VBox>

    <Region HBox.hgrow="ALWAYS"/>

    <Label text="Type 'help' for commands"
           style="-fx-font-size: 11;
                  -fx-text-fill: rgba(255,255,255,0.65);
                  -fx-font-style: italic;"/>
</HBox>
