<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<HBox xmlns:fx="http://javafx.com/fxml"
      spacing="10"
      style="-fx-background-color: #FFFFFF;
             -fx-background-radius: 14;
             -fx-border-color: #E2E8F0;
             -fx-border-radius: 14;
             -fx-border-width: 1;
             -fx-effect: dropshadow(gaussian,
                         rgba(15,23,42,0.06), 18, 0, 0, 4);">
    <padding>
        <Insets top="14" right="16" bottom="14" left="16"/>
    </padding>
    <Label fx:id="indexLabel"
           style="-fx-text-fill: #94A3B8;
                  -fx-font-size: 12;"/>
    <VBox spacing="6">
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label fx:id="groupLabel"
                   style="-fx-text-fill: #0369A1;
                          -fx-font-size: 10;
                          -fx-font-weight: bold;
                          -fx-background-color: #E0F2FE;
                          -fx-background-radius: 999;
                          -fx-padding: 4 10 4 10;"/>
            <Label fx:id="expenseNameLabel"
                   style="-fx-text-fill: #0F172A;
                          -fx-font-size: 15;
                          -fx-font-weight: bold;"/>
        </HBox>
        <Label fx:id="amountLabel"
               style="-fx-text-fill: #15803D;
                      -fx-font-size: 14;
                      -fx-font-weight: bold;"/>
        <Label fx:id="payerLabel"
               style="-fx-text-fill: #475569;
                      -fx-font-size: 12;
                      -fx-font-weight: bold;"/>
        <VBox fx:id="participantsContainer" spacing="4"/>
        <Label fx:id="tagsLabel"
               style="-fx-text-fill: #64748B;
                      -fx-font-size: 11;"
               wrapText="true"/>
    </VBox>
</HBox>
